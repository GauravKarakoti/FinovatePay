DB_USER=
DB_HOST=
DB_NAME=
DB_PASSWORD=
DB_PORT=

# ============================================
# RATE LIMITING CONFIGURATION
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5
KYC_RATE_LIMIT_WINDOW_MS=3600000
KYC_RATE_LIMIT_MAX_REQUESTS=3
PAYMENT_RATE_LIMIT_WINDOW_MS=900000
PAYMENT_RATE_MAX_REQUESTS=20
RELAYER_RATE_LIMIT_WINDOW_MS=900000
RELAYER_RATE_LIMIT_MAX_REQUESTS=10

# ============================================
# SECRETS MANAGEMENT
# ============================================
# Options: env, aws, vault (default: env)
SECRETS_PROVIDER=env

# AWS Secrets Manager (if SECRETS_PROVIDER=aws)
AWS_REGION=us-east-1
AWS_SECRET_NAME=finovatepay/secrets

# HashiCorp Vault (if SECRETS_PROVIDER=vault)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=
VAULT_SECRET_PATH=secret/data/finovatepay

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ============================================
# REQUEST SIGNING
# ============================================
REQUEST_SIGNING_SECRET=
REQUEST_SIGNING_REQUIRED=false
REQUEST_SIGNING_TOLERANCE_MS=300000

# ============================================
# IP WHITELIST
# ============================================
# Comma-separated list of IPs/CIDR ranges
IP_WHITELIST_ADMIN=
IP_WHITELIST_FINANCIAL=
IP_WHITELIST_INTERNAL=

# ============================================
# BLOCKCHAIN CONFIGURATION
# ============================================
BLOCKCHAIN_RPC_URL=https://rpc-amoy.polygon.technology/
DEPLOYER_PRIVATE_KEY=
# Smart Contract Addresses
INVOICE_REGISTRY_ADDRESS=
ESCROW_CONTRACT_ADDRESS=
COMPLIANCE_MANAGER_ADDRESS=
FRACTION_TOKEN_ADDRESS=
PRODUCE_TRACKING_ADDRESS=
FINANCING_MANAGER_ADDRESS=
FORWARDER_ADDRESS=
BRIDGE_ADAPTER_ADDRESS=
LIQUIDITY_ADAPTER_ADDRESS=

# ============================================
# SERVER CONFIGURATION
# ============================================
FRONTEND_URL=http://localhost:5173
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173
NODE_ENV=development

# ============================================
# EXTERNAL SERVICES
# ============================================
MARKET_API_KEY=
MARKET_API_URL=https://api.data.gov.in/resource/9ef84268-d588-465a-a308-a864a43d0070
GROQ_API_KEY=
SANDBOX_BASE_URL=https://test-api.sandbox.co.in
SANDBOX_API_KEY=
SANDBOX_API_SECRET=
STRIPE_SECRET_KEY=

# ============================================
# EMAIL SERVICE - MAILERSEND CONFIGURATION
# ============================================
# Get API key from: https://www.mailersend.com
# 1. Create account at MailerSend
# 2. Generate API token in dashboard
# 3. Copy token below (starts with 'mlsn.')
MAILERSEND_API_KEY=
# Example trial domain: noreply@trial-xxxxxx.mlsender.net
MAILERSEND_SENDER_EMAIL=
MAILERSEND_SENDER_NAME=FinovatePay

# ============================================
# DATABASE RESILIENCE
# ============================================
DB_MAX_RETRIES=5
DB_RETRY_BASE_DELAY=1000
DB_RETRY_MAX_DELAY=30000

# ============================================
# BLOCKCHAIN TRANSACTION QUEUE (BullMQ)
# ============================================
# Redis connection URL for the job queue
REDIS_URL=redis://localhost:6379
# Maximum retry attempts for failed blockchain transactions
BLOCKCHAIN_MAX_RETRIES=5
# Base delay in ms for exponential backoff (doubles each retry)
BLOCKCHAIN_BACKOFF_MULTIPLIER=2000
# Number of concurrent jobs the worker can process
BLOCKCHAIN_QUEUE_CONCURRENCY=3
# Rate limiting: max transactions per duration
BLOCKCHAIN_RATE_LIMIT_MAX=10
# Rate limiting duration in ms
BLOCKCHAIN_RATE_LIMIT_DURATION=1000
